    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/uuid": "^9.0.8",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.0",
    "typescript": "^5.4.5"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "tsx@4.23.0": true
